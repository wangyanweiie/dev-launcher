{
  "scanRoot": "",
  "categories": ["App", "Pc"],
  "port": 5555,
  "host": "127.0.0.1",
  "openBrowser": true,
  "scanCacheSeconds": 30,
  "wifiIp": "",
  "nodeOptions": "--max-old-space-size=2048",
  "taskEnv": {},
  "maxTaskLogLines": 200,
  "clearTaskLogsOnStop": true,
  "detectOrphanServices": true,
  "orphanDetectMinIntervalSeconds": 30,
  "maxRetainedTaskStates": 200,
  "ignoreDirNames": [
    "node_modules",
    ".git",
    "dist",
    "uni_modules",
    "internal",
    "nativeplugins",
    "android",
    "uniCloud-aliyun",
    "uniCloud",
    "cloudfunctions"
  ],
  "ignorePathSegments": [
    "/script/generate-api/",
    "/test/server/",
    "/packages/commitlint",
    "/packages/eslint-config",
    "/internal/"
  ]
}
